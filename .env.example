# Copy to .env and adjust before the first make apply.

# Required only for the first bootstrap when the Vault storage secret does not
# exist yet. Keep the real value out of Git.
VAULT_POSTGRES_CONNECTION_URL='postgresql://vault:<password>@postgresql.example.com:5432/vault'

# Optional. Defaults to the current kubectl context.
# KUBECONFIG=../terraform-homelab/configs/kubeconfig

# Optional. Generated by terraform-homelab and used to refresh the Karpenter
# Talos worker user-data in Vault after every cluster rebuild.
TALOS_WORKER_CONFIG_FILE=../terraform-homelab/configs/karpenter-talos-worker-user-data.yaml

# Usadas pelos manifests em */manifests/*.yaml via envsubst (scripts/apply-manifests.sh)
# e pelo fallback de scripts/seed-vault-secrets.sh. Dominio, storage class e
# regiao/zona do Proxmox usados pelos charts Helm ficam fixos direto nos
# values.yaml de cada app (fonte unica de verdade) - mudar de cluster/dominio
# no futuro significa editar esses values.yaml, nao esta variavel.
CLUSTER_DOMAIN=henriqzimer.com.br
ACME_EMAIL=henrique.zimermann@outlook.com.br
CLOUDFLARE_EMAIL=henrique.zimermann@outlook.com.br
METALLB_ADDRESS_RANGE=192.168.1.150-192.168.1.155
PROXMOX_REGION=pve
